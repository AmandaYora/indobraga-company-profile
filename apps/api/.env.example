NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api/v1

DATABASE_URL=mysql://indobraga:indobraga@localhost:3306/indobraga
SHADOW_DATABASE_URL=mysql://indobraga:indobraga@localhost:3306/indobraga_shadow

SESSION_COOKIE_NAME=indobraga_admin_session
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_SESSION_TTL_DAYS=7
CSRF_COOKIE_NAME=indobraga_csrf
CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://indobraga.com,https://www.indobraga.com

PUBLIC_SITE_URL=https://indobraga.com
PUBLIC_MEDIA_URL=https://media.indobraga.com

UPLOAD_IMAGE_MAX_MB=10
UPLOAD_VIDEO_MAX_MB=100
UPLOAD_VIDEO_MAX_DURATION_SECONDS=120
MEDIA_THUMBNAIL_MAX_WIDTH=480
MEDIA_MEDIUM_MAX_WIDTH=960
MEDIA_LARGE_MAX_WIDTH=1600
MEDIA_VIDEO_POSTER_MAX_WIDTH=960
MEDIA_OBJECT_PREFIX=upload
MEDIA_STORAGE_ENV=dev
MEDIA_PATH_TIME_ZONE=Asia/Jakarta

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=.local-storage
S3_ENDPOINT=https://is3.cloudhost.id
S3_REGION=auto
S3_BUCKET=indobraga
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

INTERNAL_WORKER_SECRET=replace-with-worker-secret
EMAIL_PROVIDER_MODE=mock
SMTP_TEST_TIMEOUT_MS=10000
EMAIL_CAMPAIGN_RECIPIENT_MAX=1000
EMAIL_WORKER_BATCH_SIZE=50
EMAIL_WORKER_MAX_ATTEMPTS=3
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/oauth/google/email/callback
