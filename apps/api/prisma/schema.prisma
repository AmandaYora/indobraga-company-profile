generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  CONTENT_EDITOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  INACTIVE
  ARCHIVED
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
  SPAM
}

enum WhatsAppLeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
  SPAM
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaStatus {
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
  PENDING_DELETE
  DELETED
  CLEANUP_FAILED
}

enum EmailProviderType {
  GOOGLE_OAUTH
  SMTP_HOSTING
}

enum EmailAccountStatus {
  CONNECTED
  INVALID
  DISABLED
  NEEDS_RECONNECT
}

enum SmtpSecurityMode {
  SSL_TLS
  STARTTLS
  NONE
}

enum EmailCampaignStatus {
  DRAFT
  PENDING
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum EmailRecipientStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  SKIPPED
}

enum MarketingContactSource {
  INQUIRY
  WHATSAPP_LEAD
  MANUAL_IMPORT
  MANUAL
}

enum MarketingContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BLOCKED
}

enum MarketingConsentStatus {
  IMPLIED
  EXPLICIT
  UNKNOWN
}

enum RevalidationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  INQUIRY_CREATED
  WHATSAPP_LEAD_CREATED
  EMAIL_CAMPAIGN_COMPLETED
  EMAIL_CAMPAIGN_FAILED
  MEDIA_FAILED
  SMTP_INVALID
  SYSTEM_WARNING
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationEmailJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model User {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(120)
  email        String     @unique @db.VarChar(190)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         UserRole
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  sessions          AdminSession[]
  uploadedMedia     MediaFile[]        @relation("MediaCreatedBy")
  createdCampaign   EmailCampaign[]    @relation("CampaignCreatedBy")
  auditLogs         AuditLog[]
  emailOAuthStates  EmailOAuthState[]  @relation("EmailOAuthStateAdmin")
  notificationReads NotificationRead[]

  @@map("users")
}

model AdminSession {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipHash    String?   @map("ip_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model SiteSettings {
  id                     Int      @id @default(1)
  brand                  String   @default("Indobraga") @db.VarChar(120)
  legalName              String   @default("PT. Braga Indonesia Perkasa") @map("legal_name") @db.VarChar(190)
  email                  String   @default("indobraga@gmail.com") @db.VarChar(190)
  phone                  String   @default("0851-5870-0895") @db.VarChar(50)
  whatsapp               String   @default("6285158700895") @db.VarChar(50)
  instagram              String   @default("indobraga") @db.VarChar(120)
  contactPerson          String   @default("Mahardika") @map("contact_person") @db.VarChar(120)
  contactRole            String   @default("Tim Marketing") @map("contact_role") @db.VarChar(120)
  address                String   @default("Jalan Babakan Tarogong No. 292, Kota Bandung") @db.VarChar(500)
  seoTitle               String?  @map("seo_title") @db.VarChar(190)
  seoDescription         String?  @map("seo_description") @db.VarChar(500)
  showBrandText          Boolean  @default(false) @map("show_brand_text")
  logoMediaFileId        Int?     @map("logo_media_file_id")
  ogMediaFileId          Int?     @map("og_media_file_id")
  contactHeroMediaFileId Int?     @map("contact_hero_media_file_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  logoMediaFile        MediaFile? @relation("SiteSettingsLogoMedia", fields: [logoMediaFileId], references: [id], onDelete: SetNull)
  ogMediaFile          MediaFile? @relation("SiteSettingsOgMedia", fields: [ogMediaFileId], references: [id], onDelete: SetNull)
  contactHeroMediaFile MediaFile? @relation("SiteSettingsContactHeroMedia", fields: [contactHeroMediaFileId], references: [id], onDelete: SetNull)

  @@map("site_settings")
}

model HeroSection {
  id             Int            @id @default(autoincrement())
  title          String         @db.VarChar(190)
  subtitle       String?        @db.VarChar(500)
  ctaLabel       String?        @map("cta_label") @db.VarChar(120)
  ctaHref        String?        @map("cta_href") @db.VarChar(255)
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  slides HeroSlide[]

  @@index([status, archivedAt])
  @@map("hero_sections")
}

model HeroSlide {
  id             Int            @id @default(autoincrement())
  heroSectionId  Int            @map("hero_section_id")
  label          String?        @db.VarChar(120)
  title          String         @db.VarChar(190)
  metric         String?        @db.VarChar(120)
  altText        String?        @map("alt_text") @db.VarChar(255)
  mediaFileId    Int?           @map("media_file_id")
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  heroSection HeroSection @relation(fields: [heroSectionId], references: [id], onDelete: Cascade)
  mediaFile   MediaFile?  @relation("HeroSlideMedia", fields: [mediaFileId], references: [id], onDelete: SetNull)

  @@index([heroSectionId, sortOrder])
  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("hero_slides")
}

model Partner {
  id             Int            @id @default(autoincrement())
  name           String         @db.VarChar(190)
  segment        String?        @db.VarChar(120)
  logoMediaId    Int?           @map("logo_media_id")
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  logoMedia MediaFile? @relation("PartnerLogoMedia", fields: [logoMediaId], references: [id], onDelete: SetNull)

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("partners")
}

model ProductionStrength {
  id             Int            @id @default(autoincrement())
  label          String         @db.VarChar(120)
  value          String         @db.VarChar(50)
  suffix         String?        @db.VarChar(120)
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("production_strengths")
}

model PortfolioCategory {
  id             Int            @id @default(autoincrement())
  name           String         @unique @db.VarChar(120)
  slug           String         @unique @db.VarChar(140)
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  portfolios Portfolio[]

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("portfolio_categories")
}

model Portfolio {
  id             Int            @id @default(autoincrement())
  title          String         @db.VarChar(190)
  slug           String         @unique @db.VarChar(190)
  category       String         @db.VarChar(120)
  categoryId     Int?           @map("category_id")
  description    String?        @db.VarChar(700)
  imageMediaId   Int?           @map("image_media_id")
  featured       Boolean        @default(false)
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(DRAFT)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  publishedAt    DateTime?      @map("published_at")
  seoTitle       String?        @map("seo_title") @db.VarChar(190)
  seoDescription String?        @map("seo_description") @db.VarChar(500)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  imageMedia  MediaFile?         @relation("PortfolioImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)
  categoryRef PortfolioCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([status, featured, sortOrder])
  @@index([status, category, sortOrder])
  @@index([status, categoryId, sortOrder])
  @@index([status, archivedAt])
  @@map("portfolios")
}

model Machine {
  id             Int            @id @default(autoincrement())
  name           String         @db.VarChar(190)
  slug           String         @unique @db.VarChar(190)
  metric         String?        @db.VarChar(120)
  description    String?        @db.VarChar(700)
  imageMediaId   Int?           @map("image_media_id")
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  imageMedia MediaFile? @relation("MachineImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("machines")
}

model PrintingCapacity {
  id             Int            @id @default(autoincrement())
  label          String         @db.VarChar(120)
  value          String         @db.VarChar(50)
  unit           String         @db.VarChar(120)
  description    String?        @db.VarChar(700)
  imageMediaId   Int?           @map("image_media_id")
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  imageMedia MediaFile? @relation("PrintingCapacityImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("printing_capacities")
}

model ProductionCapacity {
  id             Int            @id @default(autoincrement())
  product        String         @db.VarChar(120)
  value          String         @db.VarChar(50)
  unit           String         @db.VarChar(120)
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("production_capacities")
}

model ServiceItem {
  id             Int            @id @default(autoincrement())
  name           String         @db.VarChar(190)
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(PUBLISHED)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([status, sortOrder])
  @@index([status, archivedAt])
  @@map("services")
}

model GalleryItem {
  id             Int            @id @default(autoincrement())
  type           MediaKind
  caption        String         @db.VarChar(500)
  mediaFileId    Int?           @map("media_file_id")
  posterMediaId  Int?           @map("poster_media_id")
  sortOrder      Int            @default(0) @map("sort_order")
  status         ContentStatus  @default(DRAFT)
  previousStatus ContentStatus? @map("previous_status")
  archivedAt     DateTime?      @map("archived_at")
  archivedById   Int?           @map("archived_by")
  publishedAt    DateTime?      @map("published_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  mediaFile   MediaFile? @relation("GalleryMedia", fields: [mediaFileId], references: [id], onDelete: SetNull)
  posterMedia MediaFile? @relation("GalleryPosterMedia", fields: [posterMediaId], references: [id], onDelete: SetNull)

  @@index([status, sortOrder])
  @@index([status, publishedAt])
  @@index([status, archivedAt])
  @@map("gallery_items")
}

model NewsArticle {
  id               Int            @id @default(autoincrement())
  title            String         @db.VarChar(190)
  slug             String         @unique @db.VarChar(190)
  category         String         @db.VarChar(120)
  excerpt          String         @db.VarChar(700)
  content          Json
  thumbnailMediaId Int?           @map("thumbnail_media_id")
  ogMediaId        Int?           @map("og_media_id")
  status           ContentStatus  @default(DRAFT)
  previousStatus   ContentStatus? @map("previous_status")
  archivedAt       DateTime?      @map("archived_at")
  archivedById     Int?           @map("archived_by")
  publishedAt      DateTime?      @map("published_at")
  seoTitle         String?        @map("seo_title") @db.VarChar(190)
  seoDescription   String?        @map("seo_description") @db.VarChar(500)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  thumbnailMedia MediaFile? @relation("NewsThumbnailMedia", fields: [thumbnailMediaId], references: [id], onDelete: SetNull)
  ogMedia        MediaFile? @relation("NewsOgMedia", fields: [ogMediaId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([status, category, publishedAt])
  @@index([status, archivedAt])
  @@map("news")
}

model Inquiry {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(120)
  email              String        @db.VarChar(190)
  phone              String        @db.VarChar(50)
  company            String?       @db.VarChar(190)
  message            String        @db.Text
  status             InquiryStatus @default(NEW)
  internalNote       String?       @map("internal_note") @db.Text
  notificationStatus String?       @map("notification_status") @db.VarChar(50)
  source             String?       @db.VarChar(120)
  meta               Json?
  archivedAt         DateTime?     @map("archived_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([email])
  @@map("inquiries")
}

model WhatsAppLead {
  id           Int                @id @default(autoincrement())
  name         String             @db.VarChar(120)
  phone        String             @db.VarChar(50)
  message      String?            @db.VarChar(700)
  whatsappUrl  String?            @map("whatsapp_url") @db.VarChar(1000)
  status       WhatsAppLeadStatus @default(NEW)
  internalNote String?            @map("internal_note") @db.Text
  source       String?            @db.VarChar(120)
  meta         Json?
  archivedAt   DateTime?          @map("archived_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([phone])
  @@map("whatsapp_leads")
}

model MediaFile {
  id                Int          @id @default(autoincrement())
  kind              MediaKind
  status            MediaStatus  @default(PROCESSING)
  originalFilename  String       @map("original_filename") @db.VarChar(255)
  mimeType          String       @map("mime_type") @db.VarChar(120)
  extension         String?      @db.VarChar(20)
  objectKey         String?      @unique @map("object_key") @db.VarChar(500)
  publicUrl         String?      @map("public_url") @db.VarChar(1000)
  thumbnailUrl      String?      @map("thumbnail_url") @db.VarChar(1000)
  mediumUrl         String?      @map("medium_url") @db.VarChar(1000)
  largeUrl          String?      @map("large_url") @db.VarChar(1000)
  posterUrl         String?      @map("poster_url") @db.VarChar(1000)
  videoUrl          String?      @map("video_url") @db.VarChar(1000)
  sizeOriginalBytes BigInt?      @map("size_original_bytes")
  sizeFinalBytes    BigInt?      @map("size_final_bytes")
  width             Int?
  height            Int?
  durationSeconds   Int?         @map("duration_seconds")
  checksum          String?      @db.VarChar(128)
  variants          Json?
  errorMessage      String?      @map("error_message") @db.Text
  createdById       Int?         @map("created_by_id")
  previousStatus    MediaStatus? @map("previous_status")
  archivedAt        DateTime?    @map("archived_at")
  archivedById      Int?         @map("archived_by")
  deletedAt         DateTime?    @map("deleted_at")
  deletedById       Int?         @map("deleted_by")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  createdBy               User?              @relation("MediaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  siteSettingsLogo        SiteSettings[]     @relation("SiteSettingsLogoMedia")
  siteSettingsOg          SiteSettings[]     @relation("SiteSettingsOgMedia")
  siteSettingsContactHero SiteSettings[]     @relation("SiteSettingsContactHeroMedia")
  heroSlides              HeroSlide[]        @relation("HeroSlideMedia")
  partnerLogos            Partner[]          @relation("PartnerLogoMedia")
  portfolioImages         Portfolio[]        @relation("PortfolioImageMedia")
  machineImages           Machine[]          @relation("MachineImageMedia")
  printingCapacityImages  PrintingCapacity[] @relation("PrintingCapacityImageMedia")
  galleryMediaItems       GalleryItem[]      @relation("GalleryMedia")
  galleryPosterItems      GalleryItem[]      @relation("GalleryPosterMedia")
  newsThumbnailArticles   NewsArticle[]      @relation("NewsThumbnailMedia")
  newsOgArticles          NewsArticle[]      @relation("NewsOgMedia")

  @@index([kind, status, createdAt])
  @@index([status, archivedAt])
  @@index([status, deletedAt])
  @@index([createdById])
  @@map("media_files")
}

model EmailAccount {
  id                    Int                @id @default(autoincrement())
  provider              EmailProviderType
  email                 String             @db.VarChar(190)
  displayName           String             @map("display_name") @db.VarChar(190)
  status                EmailAccountStatus @default(DISABLED)
  googleSubject         String?            @map("google_subject") @db.VarChar(190)
  encryptedAccessToken  String?            @map("encrypted_access_token") @db.Text
  encryptedRefreshToken String?            @map("encrypted_refresh_token") @db.Text
  tokenExpiresAt        DateTime?          @map("token_expires_at")
  smtpHost              String?            @map("smtp_host") @db.VarChar(190)
  smtpPort              Int?               @map("smtp_port")
  smtpSecurity          SmtpSecurityMode?  @map("smtp_security")
  smtpUsername          String?            @map("smtp_username") @db.VarChar(190)
  encryptedSmtpPassword String?            @map("encrypted_smtp_password") @db.Text
  lastTestAt            DateTime?          @map("last_test_at")
  connectedAt           DateTime?          @map("connected_at")
  lastError             String?            @map("last_error") @db.Text
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  campaigns EmailCampaign[]

  @@unique([provider, email])
  @@index([status, provider])
  @@map("email_accounts")
}

model EmailOAuthState {
  id          Int       @id @default(autoincrement())
  stateHash   String    @unique @map("state_hash") @db.VarChar(128)
  adminUserId Int?      @map("admin_user_id")
  emailHint   String?   @map("email_hint") @db.VarChar(190)
  displayName String?   @map("display_name") @db.VarChar(190)
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  adminUser User? @relation("EmailOAuthStateAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("email_oauth_states")
}

model MarketingContact {
  id                Int                    @id @default(autoincrement())
  email             String                 @unique @db.VarChar(190)
  name              String?                @db.VarChar(190)
  phone             String?                @db.VarChar(50)
  company           String?                @db.VarChar(190)
  source            MarketingContactSource @default(INQUIRY)
  sourceRefId       Int?                   @map("source_ref_id")
  status            MarketingContactStatus @default(ACTIVE)
  consentStatus     MarketingConsentStatus @default(IMPLIED) @map("consent_status")
  tags              Json?
  lastInteractionAt DateTime?              @map("last_interaction_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  campaignRecipients EmailCampaignRecipient[]

  @@index([status, createdAt])
  @@index([source, sourceRefId])
  @@index([lastInteractionAt])
  @@map("marketing_contacts")
}

model EmailCampaign {
  id              Int                 @id @default(autoincrement())
  senderAccountId Int                 @map("sender_account_id")
  createdById     Int?                @map("created_by_id")
  name            String              @db.VarChar(190)
  subject         String              @db.VarChar(255)
  bodyText        String?             @map("body_text") @db.Text
  bodyHtml        String?             @map("body_html") @db.Text
  status          EmailCampaignStatus @default(DRAFT)
  totalRecipients Int                 @default(0) @map("total_recipients")
  queuedCount     Int                 @default(0) @map("queued_count")
  sentCount       Int                 @default(0) @map("sent_count")
  failedCount     Int                 @default(0) @map("failed_count")
  lockedAt        DateTime?           @map("locked_at")
  startedAt       DateTime?           @map("started_at")
  finishedAt      DateTime?           @map("finished_at")
  lastError       String?             @map("last_error") @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  senderAccount EmailAccount             @relation(fields: [senderAccountId], references: [id], onDelete: Restrict)
  createdBy     User?                    @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  recipients    EmailCampaignRecipient[]
  sendLogs      EmailSendLog[]

  @@index([status, createdAt])
  @@index([senderAccountId])
  @@map("email_campaigns")
}

model EmailCampaignRecipient {
  id                 Int                  @id @default(autoincrement())
  campaignId         Int                  @map("campaign_id")
  marketingContactId Int?                 @map("marketing_contact_id")
  email              String               @db.VarChar(190)
  name               String?              @db.VarChar(190)
  variables          Json?                @map("variables")
  status             EmailRecipientStatus @default(QUEUED)
  attempts           Int                  @default(0)
  nextAttemptAt      DateTime?            @map("next_attempt_at")
  lockedAt           DateTime?            @map("locked_at")
  sentAt             DateTime?            @map("sent_at")
  failedAt           DateTime?            @map("failed_at")
  errorCode          String?              @map("error_code") @db.VarChar(120)
  errorMessage       String?              @map("error_message") @db.Text
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  campaign         EmailCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  marketingContact MarketingContact? @relation(fields: [marketingContactId], references: [id], onDelete: SetNull)
  sendLogs         EmailSendLog[]

  @@unique([campaignId, email])
  @@index([campaignId, status])
  @@index([marketingContactId])
  @@index([status, nextAttemptAt])
  @@map("email_campaign_recipients")
}

model EmailSendLog {
  id           Int      @id @default(autoincrement())
  campaignId   Int      @map("campaign_id")
  recipientId  Int?     @map("recipient_id")
  provider     String   @db.VarChar(120)
  status       String   @db.VarChar(50)
  messageId    String?  @map("message_id") @db.VarChar(190)
  errorCode    String?  @map("error_code") @db.VarChar(120)
  errorMessage String?  @map("error_message") @db.Text
  responseMeta Json?    @map("response_meta")
  createdAt    DateTime @default(now()) @map("created_at")

  campaign  EmailCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient EmailCampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([recipientId])
  @@map("email_send_logs")
}

model RevalidationEvent {
  id           Int                @id @default(autoincrement())
  resourceType String             @map("resource_type") @db.VarChar(120)
  resourceId   Int?               @map("resource_id")
  cacheKey     String             @map("cache_key") @db.VarChar(255)
  status       RevalidationStatus @default(PENDING)
  attempts     Int                @default(0)
  lastError    String?            @map("last_error") @db.Text
  processedAt  DateTime?          @map("processed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([resourceType, resourceId])
  @@map("revalidation_events")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorUserId  Int?     @map("actor_user_id")
  action       String   @db.VarChar(120)
  resourceType String?  @map("resource_type") @db.VarChar(120)
  resourceId   Int?     @map("resource_id")
  ipHash       String?  @map("ip_hash") @db.VarChar(255)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Notification {
  id           Int                  @id @default(autoincrement())
  type         NotificationType
  severity     NotificationSeverity @default(INFO)
  title        String               @db.VarChar(190)
  message      String               @db.VarChar(700)
  resourceType String?              @map("resource_type") @db.VarChar(120)
  resourceId   Int?                 @map("resource_id")
  actorType    String?              @map("actor_type") @db.VarChar(120)
  actorId      Int?                 @map("actor_id")
  expiresAt    DateTime?            @map("expires_at")
  createdAt    DateTime             @default(now()) @map("created_at")

  reads     NotificationRead[]
  emailJobs NotificationEmailJob[]

  @@index([createdAt])
  @@index([type, createdAt])
  @@index([resourceType, resourceId])
  @@map("notifications")
}

model NotificationRead {
  id             Int      @id @default(autoincrement())
  notificationId Int      @map("notification_id")
  userId         Int      @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@map("notification_reads")
}

model NotificationEmailJob {
  id             Int                        @id @default(autoincrement())
  notificationId Int?                       @map("notification_id")
  recipientEmail String                     @map("recipient_email") @db.VarChar(190)
  subject        String                     @db.VarChar(255)
  bodyText       String                     @map("body_text") @db.Text
  bodyHtml       String?                    @map("body_html") @db.Text
  status         NotificationEmailJobStatus @default(PENDING)
  attempts       Int                        @default(0)
  nextAttemptAt  DateTime?                  @map("next_attempt_at")
  lockedAt       DateTime?                  @map("locked_at")
  lastError      String?                    @map("last_error") @db.Text
  sentAt         DateTime?                  @map("sent_at")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt, createdAt])
  @@index([notificationId])
  @@map("notification_email_jobs")
}
